# Mapo Environment Variables
# These override settings in mapo.yaml

# --- Proxy ---
# MAPO_PROXY_URLS=http://user:pass@proxy1:8080,socks5://user:pass@proxy2:1080
# MAPO_PROXY_ROTATION=round_robin

# --- Enrichment ---
# MAPO_ENRICHMENT_PROVIDER=rapidapi
# MAPO_ENRICHMENT_API_KEY=your-api-key-here

# --- Webhooks ---
# MAPO_WEBHOOK_URLS=https://hooks.slack.com/services/XXX/YYY/ZZZ

# --- AI (Lead Scoring) ---
# MAPO_AI_PROVIDER=anthropic          # anthropic, openai, gemini, vllm
# MAPO_AI_API_KEY=your-api-key-here
# MAPO_AI_MODEL=claude-sonnet-4-20250514
# MAPO_AI_BASE_URL=http://localhost:8001/v1   # For vLLM only
# MAPO_AI_ICP=Small restaurants, 50-200 reviews, no website, major US cities
# MAPO_AI_PRODUCT=Custom websites for restaurants with online ordering
