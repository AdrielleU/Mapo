# Mapo Environment Variables
# These override settings in mapo.yaml

# --- Proxy ---
# MAPO_PROXY_URLS=http://user:pass@proxy1:8080,socks5://user:pass@proxy2:1080
# MAPO_PROXY_ROTATION=round_robin

# --- Enrichment ---
# MAPO_ENRICHMENT_PROVIDER=rapidapi
# MAPO_ENRICHMENT_API_KEY=your-api-key-here

# --- Webhooks ---
# MAPO_WEBHOOK_URLS=https://hooks.slack.com/services/XXX/YYY/ZZZ

# --- Authentication (optional — leave empty to disable login) ---
# MAPO_USERNAME=admin
# MAPO_PASSWORD=changeme
# MAPO_TOTP_SECRET=JBSWY3DPEHPK3PXP   # Base32 secret for Google Authenticator / Authy
#   Generate a new secret: python -c "import secrets, base64; print(base64.b32encode(secrets.token_bytes(20)).decode())"
#   Same secret on multiple devices = same codes (just scan the QR or enter the secret manually)

# --- Limits & Safeguards ---
# MAPO_LIMITS_MAX_RESULTS_PER_QUERY=5000
# MAPO_LIMITS_MAX_CITIES_PER_JOB=200
# MAPO_LIMITS_MAX_TOTAL_PLACES=10000
# MAPO_LIMITS_MAX_CONCURRENT_JOBS=3
# MAPO_LIMITS_MAX_RUNTIME_MINUTES=120
# MAPO_LIMITS_WARN_THRESHOLD=1000

# --- Scraping Tuning ---
# MAPO_SCRAPING_CONCURRENCY=5
# MAPO_SCRAPING_MIN_DELAY=0.5
# MAPO_SCRAPING_MAX_DELAY=2.0
# MAPO_SCRAPING_SCROLL_TIMEOUT=40
# MAPO_SCRAPING_HEADLESS=true       # set to false for debug mode

# --- AI (Lead Scoring) ---
# MAPO_AI_PROVIDER=anthropic          # anthropic, openai, gemini, vllm
# MAPO_AI_API_KEY=your-api-key-here
# MAPO_AI_MODEL=claude-sonnet-4-20250514
# MAPO_AI_BASE_URL=http://localhost:8001/v1   # For vLLM only
# MAPO_AI_ICP=Small restaurants, 50-200 reviews, no website, major US cities
# MAPO_AI_PRODUCT=Custom websites for restaurants with online ordering
